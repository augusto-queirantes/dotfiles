#!/usr/bin/env bash
#
# tmux-feature — start a new feature in one shot.
#   1. fetches origin/main (no checkout)
#   2. creates a git worktree on a new branch off origin/main
#   3. creates a tmux session at the worktree, with two windows:
#        1: claude   (claude code running)
#        2: shell    (plain shell)
#   4. attaches (or switches if already inside tmux)
#
# Usage:
#   tmux-feature <description...>
#
# Examples:
#   tmux-feature add rate limit middleware
#   tmux-feature "fix flaky webhook test"
set -euo pipefail

if [[ $# -eq 0 ]]; then
  echo "usage: tmux-feature <description>" >&2
  exit 2
fi

desc="$*"

# Must run inside a git working tree.
git_root=$(git rev-parse --show-toplevel 2>/dev/null) || {
  echo "tmux-feature: not inside a git repository" >&2
  exit 1
}
repo_name=$(basename "$git_root")
repo_parent=$(dirname "$git_root")

# Slug the description: lowercase, kebab-case, ≤ 40 chars.
slug=$(printf '%s' "$desc" \
  | tr '[:upper:]' '[:lower:]' \
  | sed -E 's/[^a-z0-9]+/-/g; s/^-+|-+$//g' \
  | cut -c1-40 \
  | sed -E 's/-+$//')
[[ -z "$slug" ]] && { echo "tmux-feature: empty slug from: $desc" >&2; exit 1; }

# Branch namespace: first word of git user.name (lowercased), fall back to $USER.
prefix=$(git config --get user.name 2>/dev/null | awk '{print tolower($1)}')
[[ -z "$prefix" ]] && prefix="$USER"

branch="$prefix/$slug"
worktree_path="$repo_parent/$repo_name-$slug"

# Disambiguate if branch or path already exists.
n=2
while git -C "$git_root" show-ref --verify --quiet "refs/heads/$branch" \
   || git -C "$git_root" show-ref --verify --quiet "refs/remotes/origin/$branch" \
   || [[ -e "$worktree_path" ]]; do
  branch="$prefix/$slug-$n"
  worktree_path="$repo_parent/$repo_name-$slug-$n"
  n=$((n+1))
done

echo "→ fetching origin/main"
git -C "$git_root" fetch origin main

echo "→ worktree $worktree_path on $branch"
git -C "$git_root" worktree add "$worktree_path" -b "$branch" origin/main

# tmux disallows '.' and ':' in session names.
session=$(printf '%s' "$repo_name-$slug" | tr '.:' '__')

if ! tmux has-session -t="$session" 2>/dev/null; then
  echo "→ tmux session $session"
  # Window 1: claude. After claude exits, drop to a shell so the window
  # survives — closing the window kills the session if it's the last one.
  tmux new-session -ds "$session" -c "$worktree_path" -n claude \
    "claude --dangerously-skip-permissions; exec ${SHELL:-/bin/zsh}"
  tmux new-window  -t "$session:" -c "$worktree_path" -n shell
  tmux select-window -t "$session:1"

  # Stash metadata on the session so tmux-feature-end can clean up later.
  tmux set-option -t "$session" -q @feature_worktree  "$worktree_path"
  tmux set-option -t "$session" -q @feature_branch    "$branch"
  tmux set-option -t "$session" -q @feature_repo_root "$git_root"
fi

if [[ -n "${TMUX:-}" ]]; then
  tmux switch-client -t "$session"
else
  tmux attach-session -t "$session"
fi
