{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(semble *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(bat *)",
      "Bash(jq *)",
      "Bash(curl -sL *)",
      "Bash(curl -fsSL *)",
      "Bash(gh api GET *)",
      "mcp__semble__search",
      "mcp__semble__find_related"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/git-guardrail.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact|resume",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-context.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "calendar-manager@conclave": true,
    "engineer@conclave": true,
    "qa@conclave": true,
    "scribe@conclave": true,
    "foreman@conclave": true,
    "datadog@claude-plugins-official": true,
    "rainmaker@conclave": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "conclave": {
      "source": {
        "source": "github",
        "repo": "augusto-queirantes/conclave"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "credentials": {
      "files": [
        {
          "path": "~/.ssh",
          "mode": "deny"
        },
        {
          "path": "~/.aws/credentials",
          "mode": "deny"
        }
      ]
    },
    "excludedCommands": [
      "gh *",
      "docker *"
    ]
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "autoMemoryEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
