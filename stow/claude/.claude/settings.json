{
  "permissions": {
    "allow": [
      "mcp__pencil",
      "WebSearch",
      "WebFetch",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(bat *)",
      "Bash(jq *)",
      "Bash(curl -sL *)",
      "Bash(curl -fsSL *)",
      "Bash(gh api GET *)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/notify.sh\" stop"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/notify.sh\" permission"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized",
  "skipAutoPermissionPrompt": true
}
